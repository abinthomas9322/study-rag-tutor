# Copy this file to backend/.env and fill in your real key. NEVER commit .env.
# The backend reads .env from its working directory, so run uvicorn from backend/.

# Free Groq API key (no credit card): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides — sensible defaults are used if these are omitted:
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHUNK_SIZE=800
# CHUNK_OVERLAP=120
# TOP_K=4
# DB_PATH=backend/tutor.db
